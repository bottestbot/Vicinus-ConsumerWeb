generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  fullName  String?
  role      String   @default("buyer")
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loginCount          Int     @default(0)
  onboardingCompleted Boolean @default(false)
  onboardingData      Json?
  // Clerk session id of the last ping. loginCount is bumped only when a ping
  // arrives from a new session, so it counts login-sessions (not page loads).
  lastSessionId       String?

  // BRIEF-04 — the "since your last visit" boundary for the Vicinus IQ Brief.
  // Deliberately NOT Alert.readAt: markAllRead hard-deletes alerts, so the brief
  // must not touch it or the notification list silently empties. Advanced on the
  // brief's CTA click (BRIEF-12), never on view. Null ⇒ fall back to a 7-day window.
  lastBriefAt         DateTime?

  savedProperties   SavedProperty[]
  visitedProperties VisitedProperty[]
  savedSearches     SavedSearch[]
  alerts            Alert[]
  openHouseVisits   OpenHouseVisit[]
  preferenceProfile UserPreferenceProfile?
}

// BRIEF-01 — structured, queryable projection of the onboarding blob.
// `User.onboardingData` stays the source of truth; this profile is a derived
// projection (BRIEF-02 re-derives it on every onboarding step save, BRIEF-03
// backfills it). Enum-ish keys mirror the onboarding wizard's literals exactly.
model UserPreferenceProfile {
  id     String @id @default(uuid())
  userId String @unique

  goal               String? // buy | sell | rent | exploring
  timeline           String? // 3mo | 3-6mo | 6-12mo | researching
  homeType           String? // condo | townhouse | detached | presale | any
  // Parsed from the budget band DISPLAY string (e.g. "$600K–$1M") into ints —
  // never the display string. Open-ended bands leave the unbounded side null.
  budgetMin          Int?
  budgetMax          Int?
  bedroomsMin        Int? // parsed from "1+"/"2+"/"3+"/"4+"
  mortgage           String? // approved | in_progress | not_yet | cash
  workingWithRealtor String? // yes | no | open
  openToNearby       Boolean?
  // Ordered subset of schools|commute|transit|parks|dining|walkability|quiet.
  // Order encodes weight (first = highest priority). `more` is a dead wizard
  // tile and is never persisted.
  lifestylePriorities String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                    User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredNeighbourhoods UserPreferredNeighbourhood[]
}

// BRIEF-01 — preferred neighbourhoods as ROWS (not a JSON array) so the ranker
// can join on them later. Free-text names as typed in the onboarding wizard.
model UserPreferredNeighbourhood {
  id        String   @id @default(uuid())
  profileId String
  name      String
  createdAt DateTime @default(now())

  profile UserPreferenceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, name])
  @@index([profileId])
}

model Property {
  id                String  @id @default(uuid())
  ddfListingKey     String  @unique
  ddfListingId      String?
  realtorUrl        String
  status            String  @default("Active")
  displayOnInternet Boolean @default(true)

  price           Float?
  leaseAmount     Float?
  leaseFrequency  String?
  propertySubType String?
  beds            Int?
  baths           Float?
  bathsPartial    Int?
  sqft            Int?
  lotSize         Float?
  yearBuilt       Int?
  parkingTotal    Int?
  stories         Int?

  address      String?
  streetNumber String?
  streetName   String?
  city         String?
  province     String?
  postalCode   String?
  country      String  @default("Canada")
  lat          Float?
  lng          Float?

  description String?
  images      Json?
  photosCount Int?

  heating          Json?
  cooling          Json?
  basement         Json?
  parkingFeatures  Json?
  exteriorFeatures Json?

  taxAnnual Float?
  taxYear   Int?

  ddfAgentKey     String?
  ddfOfficeKey    String?
  neighbourhoodId String?

  isCuratorPick Boolean @default(false)
  editorialTag  String?

  listedAt      DateTime?
  ddfModifiedAt DateTime?
  syncedAt      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  agent         Agent?         @relation(fields: [ddfAgentKey], references: [ddfMemberKey])
  office        Office?        @relation(fields: [ddfOfficeKey], references: [ddfOfficeKey])
  neighbourhood Neighbourhood? @relation(fields: [neighbourhoodId], references: [id])
  openHouses    OpenHouse[]
  alerts        Alert[]
}

model Agent {
  id            String    @id @default(uuid())
  ddfMemberKey  String    @unique
  fullName      String?
  jobTitle      String?
  phone         String?
  emailVisible  Boolean   @default(false)
  province      String?
  avatarUrl     String?
  socialMedia   Json?
  ddfOfficeKey  String?
  ddfModifiedAt DateTime?
  syncedAt      DateTime  @default(now())

  office     Office?    @relation(fields: [ddfOfficeKey], references: [ddfOfficeKey])
  properties Property[]
}

model Office {
  id            String    @id @default(uuid())
  ddfOfficeKey  String    @unique
  name          String
  phone         String?
  address       String?
  city          String?
  province      String?
  logoUrl       String?
  ddfModifiedAt DateTime?
  syncedAt      DateTime  @default(now())

  agents     Agent[]
  properties Property[]
}

model OpenHouse {
  id              String    @id @default(uuid())
  ddfOpenHouseKey String    @unique
  ddfListingKey   String?
  openHouseDate   DateTime?
  startTime       String?
  endTime         String?
  openHouseType   String?
  status          String?
  remarks         String?

  property Property? @relation(fields: [ddfListingKey], references: [ddfListingKey])
}

model Neighbourhood {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  city         String?
  province     String?
  bio          String?
  medianPrice  Float?
  walkScore    Int?
  transitScore Int?
  livingGrade  String?
  videoUrl     String?
  photos       Json?
  lat          Float?
  lng          Float?
  createdAt    DateTime @default(now())

  // NBHD-01 — geographic unit + percentile reference frame.
  // `boundary` holds a GeoJSON Polygon/MultiPolygon (Json, not PostGIS — the DB
  // has no postgis extension and v1 does no native geo queries). Polygon
  // ingestion (StatsCan / curated) is a separate data task and is not wired
  // here; `centroidLat/Lng` fall back to `lat/lng` until boundaries land.
  // `referenceRegion` is the pool the "Top X%" percentile is computed against
  // (defaults to `city ?? province` when scores are computed).
  boundary        Json?
  centroidLat     Float?
  centroidLng     Float?
  referenceRegion String?

  // NBHD-07 — deterministic livability composite + versioned, reproducible
  // storage. These computed scores are the source of truth going forward; the
  // legacy seeded `walkScore`/`transitScore`/`livingGrade` above are retained
  // for backwards-compat but superseded by the `*Score` floats below.
  livabilityScore         Float?
  walkabilityScore        Float?
  transitSubScore         Float? // computed transit sub-score (legacy `transitScore Int?` kept intact)
  schoolsScore            Float?
  amenitiesScore          Float?
  livabilityPercentile    Float?
  livabilityWeightsVersion String?
  livabilityComputedAt    DateTime?

  // VIBE-01 — "neighbourhood vibe" raw inputs from OSM ways (not points, so not
  // in NeighbourhoodPoi): cycling infra length, green land-use coverage, and
  // proximity to the major noise sources. Nullable distances mean "none within
  // the search radius". Data-only for now; the vibe model/UI are downstream.
  bikeLaneKm            Float?
  greenCoverPct         Float?
  nearestMajorRoadM     Float?
  nearestRailM          Float?
  nearestAirportM       Float?
  vibeMetricsVersion    String?
  vibeMetricsComputedAt DateTime?

  properties      Property[]
  localEssentials LocalEssential[]
  pois            NeighbourhoodPoi[]
}

// NBHD-02 — raw OSM/Overpass POIs, snapshotted per ingestion run so a quarterly
// refresh can be applied atomically and older snapshots pruned. ODbL attribution
// is required wherever these are surfaced (see PoiIngestionService).
model NeighbourhoodPoi {
  id              String   @id @default(uuid())
  neighbourhoodId String
  osmId           String
  category        String
  name            String?
  lat             Float
  lng             Float
  snapshotVersion String
  createdAt       DateTime @default(now())

  neighbourhood Neighbourhood @relation(fields: [neighbourhoodId], references: [id])

  @@index([neighbourhoodId])
  @@index([neighbourhoodId, category])
  @@index([neighbourhoodId, snapshotVersion])
}

model LocalEssential {
  id              String  @id @default(uuid())
  neighbourhoodId String
  category        String
  name            String?
  rating          Float?
  distanceKm      Float?

  neighbourhood Neighbourhood @relation(fields: [neighbourhoodId], references: [id])
}

model SavedProperty {
  id         String   @id @default(uuid())
  userId     String
  // Stores the DDF ListingKey (not a Property.id FK). The listing is resolved
  // on read against the synced Property table, with a live DDF fallback, so a
  // user can save any listing without it being persisted locally first.
  propertyId String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, propertyId])
}

model VisitedProperty {
  id         String   @id @default(uuid())
  userId     String
  // DDF ListingKey — see note on SavedProperty.propertyId
  propertyId String
  visitedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, propertyId])
}

model SavedSearch {
  id        String   @id @default(uuid())
  userId    String
  name      String?
  filters   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum AlertType {
  NEW_LISTING
  PRICE_DROP
  STATUS_CHANGE
  OPEN_HOUSE
}

enum OpenHouseStatus {
  PLANNED
  ATTENDED
  SKIPPED
}

model Alert {
  id              String    @id @default(uuid())
  userId          String
  type            AlertType
  propertyId      String?
  ddfOpenHouseKey String?
  payload         Json
  createdAt       DateTime  @default(now())
  readAt          DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@unique([userId, propertyId, type])
  @@unique([userId, ddfOpenHouseKey])
  @@index([userId, readAt])
  @@index([userId, type])
}

model OpenHouseVisit {
  id              String          @id @default(uuid())
  userId          String
  ddfOpenHouseKey String
  // DDF ListingKey (not a Property FK) — a user can schedule an open house
  // for a listing that hasn't synced locally yet (e.g. via the live
  // NearbyOpenHouses carousel), so this mirrors SavedProperty/VisitedProperty's
  // loose-string convention instead of a hard FK.
  propertyId      String?
  status          OpenHouseStatus @default(PLANNED)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ddfOpenHouseKey])
  @@index([userId, status])
}

model EditorialCuration {
  id          String    @id @default(uuid())
  title       String?
  subtitle    String?
  description String?
  imageUrl    String?
  category    String?
  tag         String?
  ctaUrl      String?
  position    Int       @default(0)
  propertyIds String[]
  publishedAt DateTime?
}

model SellerLead {
  id                 String   @id @default(uuid())
  address            String
  sellingPriority    String?
  biggestHurdle      String?
  advisoryPreference String?
  firstName          String?
  lastName           String?
  email              String?
  phone              String?
  // Cached Gemini-generated valuation returned to the seller.
  valuation          Json?
  createdAt          DateTime @default(now())
}

// Realtor Hub coming-soon page — early-access / founding-member signups.
model RealtorWaitlist {
  id         String   @id @default(uuid())
  fullName   String
  email      String   @unique
  brokerage  String?
  cityMarket String?
  // Where the signup originated (e.g. "realtor-hub"). Useful once other
  // surfaces feed the same list.
  source     String?
  createdAt  DateTime @default(now())
}

model DdfSyncLog {
  id                    String    @id @default(uuid())
  entity                String
  syncedAt              DateTime  @default(now())
  recordsSynced         Int       @default(0)
  lastModifiedTimestamp DateTime?
  status                String    @default("success")
  errorMessage          String?
}
